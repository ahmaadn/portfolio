---
interface TickerItem {
	label: string;
	title: string;
	meta: string;
}

interface Props {
	items: TickerItem[];
	duration?: string;
}

const { items, duration = "30s" } = Astro.props;
---

<div class="marquee absolute bottom-0 left-0 z-[30] w-full border-t border-white/10 bg-black py-4">
	<div class="marquee-track space-x-12">
		<div class="marquee-content flex items-center gap-12 whitespace-nowrap">
			{
				items.map((item) => (
					<div class="flex items-center space-x-6">
						<span class="bg-primary px-2 py-0.5 text-[10px] font-black tracking-[0.2em] text-black uppercase">
							{item.label}
						</span>
						<span class="text-sm font-bold tracking-wider text-white uppercase">
							{item.title}
						</span>
						<span class="font-mono text-xs tracking-tighter text-white/50">
							— {item.meta}
						</span>
					</div>
				))
			}
		</div>
	</div>
</div>
