---
import { Icon } from "astro-icon/components";

interface Props {
	name: string;
	icon: string;
	[key: string]: any;
}
const { name, icon } = Astro.props;
---

<span
	class="border-border bg-main text-content hover:border-content-muted/30 hover:bg-main-light inline-flex w-fit items-center gap-2 rounded-md border px-3 py-2 transition-colors duration-200">
	<Icon name={icon} width="18" height="18" />
	<span class="text-sm">{name}</span>
</span>
