---
interface Props {
	remoteAddr?: string;
	statusText?: string;
	class?: string;
}

const {
	remoteAddr = "127.0.0.1",
	statusText = "ESTABLISHING_SECURE_CONNECTION...",
	class: className = "",
} = Astro.props;
---

<div
	class:list={[
		"bg-primary-content relative p-8 font-mono text-white md:col-span-6 md:p-12",
		className,
	]}>
	<div class="text-base-400 absolute top-4 right-4 text-[10px]">
		REMOTE_ADDR: {remoteAddr}
	</div>
	<div class="space-y-8">
		<slot />
	</div>
	<div class="text-base-400 mt-12 flex items-center justify-between text-[9px]">
		<span>{statusText}</span>
		<span class="animate-pulse">_</span>
	</div>
</div>
