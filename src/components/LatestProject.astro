---
import { cn } from "@/lib/utils";
import type { HTMLAttributes } from "astro/types";
import type { InferEntrySchema } from "astro:content";

interface Props extends Omit<HTMLAttributes<"div">, "class"> {
	project: InferEntrySchema<"projects">;
	class?: string;
}

const { project, class: className = "", ...attrs } = Astro.props;
---

<div class={cn("z-20 block shrink-0", className)} {...attrs}>
	<div class="max-w-sm">
		<div class="mb-3 flex items-center gap-3">
			<div class="bg-primary h-0.5 w-6"></div>
			<h2 class="text-content text-base font-semibold tracking-widest uppercase">
				Latest Project
			</h2>
		</div>
		<div class:list={["flex", className]} {...Astro.props}>
			<div class="flex flex-col gap-y-4 lg:max-w-lg">
				<div class="">
					<a href={project.url} target="_blank" class="link text-content text-lg font-semibold"
						>{project.title}</a
					>
					<p class="text-sm">{project.description}</p>
				</div>
			</div>
		</div>
	</div>
</div>
