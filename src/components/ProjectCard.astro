---
import Badge from "@/components/Badge.astro";
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import type { InferEntrySchema } from "astro:content";

interface Props {
	project: InferEntrySchema<"projects">;
}

const { project } = Astro.props;
---

<article class="project-card group">
	<!-- Thumbnail -->
	<div class="relative aspect-video overflow-hidden">
		<Image
			src={project.thumbnail}
			alt={project.title}
			class="h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
		/>
		<!-- Gradient overlay on hover -->
		<div
			class="pointer-events-none absolute inset-0 bg-linear-to-t from-black/40 via-transparent to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100">
		</div>
	</div>

	<!-- Content -->
	<div class="flex flex-1 flex-col p-5">
		<!-- Tags row -->
		<div class="mb-3 flex flex-wrap gap-1.5">
			{project.tags.map((tag) => <Badge>{tag}</Badge>)}
		</div>

		<h3 class="text-content mb-2 truncate text-lg leading-tight font-semibold">
			{project.title}
		</h3>

		<p class="mb-5 line-clamp-3 h-17 text-sm leading-relaxed">
			{project.description}
		</p>

		<!-- Footer -->
		<div class="mt-auto flex items-center">
			<a
				href={project.url}
				target="_blank"
				rel="noopener noreferrer"
				class="text-content-muted hover:text-content group/link inline-flex items-center justify-center gap-1.5 text-sm transition-colors">
				<Icon name="ri:github-fill" class="h-4 w-4" />
				<span>Source Code</span>
				<Icon
					name="ri:arrow-right-up-line"
					class="h-3.5 w-3.5 transition-transform duration-200 group-hover/link:translate-x-0.5 group-hover/link:-translate-y-0.5"
				/>
			</a>
		</div>
	</div>
</article>

<style>
	.project-card {
		display: flex;
		flex-direction: column;
		overflow: hidden;
		border-radius: 0.25rem;
		border-top-right-radius: 1.5rem;
		border-bottom-left-radius: 1.5rem;
		border: 1px solid var(--border);
		background-color: var(--main-light);
		transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.project-card:hover {
		border-color: var(--border-muted);
		box-shadow:
			0 8px 30px oklch(from var(--content) l c h / 0.06),
			0 2px 8px oklch(from var(--content) l c h / 0.03);
		/* transform: translateY(-2px); */
	}
</style>
