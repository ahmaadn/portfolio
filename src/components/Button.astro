---
import { cn } from "@/lib/utils";
import Icon from "astro-iconify";

interface Props {
	label: string;
	url?: string;
	icon?: string;
	"icon-class"?: string;
	"icon-left"?: string;
	"icon-left-class"?: string;
	"icon-right"?: string;
	"icon-right-class"?: string;
	class?: string;
	as?: "a" | "button";
}

const {
	label,
	href,
	icon,
	"icon-class": iconClass = "h-4 w-4",
	"icon-left": iconLeft = "",
	"icon-left-class": iconLeftClass = "h-4 w-4",
	"icon-right": iconRight,
	"icon-right-class": iconRightClass = "h-4 w-4",
	class: className = "",
	as: Element = "a",
	...extra
} = Astro.props;

const primaryIcon = iconLeft ? iconLeft : icon;
const primaryIconClass = iconLeftClass ? iconLeftClass : iconClass;

// Conditional props based on element type
const elementProps = Element === "a" ? { href } : { type: "button" };
---

<Element
	{...elementProps}
	class={cn(
		"blend group bg-main-light text-content border-base flex items-center space-x-3 rounded-none border-l-4 px-8 py-4 text-sm font-black tracking-widest uppercase shadow-xl transition-transform hover:translate-x-2",
		className
	)}
	{...extra}>
	{primaryIcon && <Icon name={primaryIcon} class={cn(primaryIconClass, "icon-left")} />}
	{label}
	{iconRight && <Icon name={iconRight} class={cn(iconRightClass, "icon-right")} />}
</Element>
