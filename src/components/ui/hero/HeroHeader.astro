---
import { cn } from "@/lib/utils";

interface Props {
	class?: string;
}

const { class: className = "" } = Astro.props;
---

<header class={cn("grid-overlay relative h-screen min-h-[800px] overflow-hidden", className)}>
	<div class="scanline pointer-events-none absolute inset-0 opacity-50"></div>
	<slot />
</header>
