---
import { cn } from "@/lib/utils";
import type { HTMLAttributes } from "astro/types";

interface Props extends Omit<HTMLAttributes<"div">, "class"> {
	class?: string;
}

const { class: className, ...attrs } = Astro.props;
---

<div
	id="open-for-work"
	class={cn(
		"relative inline-flex items-center gap-2.5 overflow-hidden rounded-full px-4 py-1.5 text-sm font-medium",
		className
	)}
	{...attrs}>
	<span class="relative flex h-2.5 w-2.5">
		<span
			class="bg-success absolute inline-flex h-full w-full animate-ping rounded-full opacity-75">
		</span>
		<span class="bg-success relative inline-flex h-2.5 w-2.5 rounded-full"></span>
	</span>
	<span class="text-content">Available for work</span>
</div>

<style>
	#open-for-work {
		--rainbow-gradient: linear-gradient(
			90deg,
			var(--error),
			var(--success),
			var(--success),
			var(--info),
			var(--info),
			hsl(195, 100%, 63%),
			hsl(195, 100%, 63%),
			hsl(270, 100%, 63%),
			hsl(270, 100%, 63%),
			var(--error)
		);

		background:
			linear-gradient(var(--color-main-light), var(--color-main-light)),
			linear-gradient(var(--color-main-light) 50%, rgba(255, 255, 255, 0.6) 80%, transparent),
			var(--rainbow-gradient);
		background-size: 200%;
		animation: rainbow-shift 4s linear infinite;
	}

	#open-for-work:where([data-theme="dark"], [data-theme="dark"] *) {
		background:
			linear-gradient(var(--color-main-light), var(--color-main-light)),
			linear-gradient(var(--color-main-light) 50%, rgba(18, 18, 19, 0.6) 80%, transparent),
			var(--rainbow-gradient);
		background-size: 200%;
	}

	#open-for-work::before {
		content: "";
		position: absolute;
		inset: 0;
		border-radius: inherit;
		padding: 1.5px;
		background: var(--rainbow-gradient);
		background-size: 200%;
		animation: rainbow-shift 4s linear infinite;
		mask:
			linear-gradient(#fff 0 0) content-box,
			linear-gradient(#fff 0 0);
		mask-composite: exclude;
		-webkit-mask:
			linear-gradient(#fff 0 0) content-box,
			linear-gradient(#fff 0 0);
		-webkit-mask-composite: xor;
	}

	@keyframes rainbow-shift {
		0% {
			background-position: 0% 50%;
		}
		100% {
			background-position: 200% 50%;
		}
	}
</style>
