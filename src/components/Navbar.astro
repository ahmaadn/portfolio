---
import { cn } from "@/lib/utils";
import Icon from "astro-iconify";
import ThemeButton from "./ThemeButton.astro";

interface Props {
	class: string;
}

const menuItems = [
	{
		name: "Projects",
		link: "/projects",
	},
	{
		name: "Contact",
		link: "/#contact",
	},
];

const { class: className = "" } = Astro.props;
---

<nav class={cn("absolute top-0 left-0 z-50 w-full", className)}>
	<div class="mx-auto flex max-w-7xl flex-col gap-4 px-6 py-8">
		<div class="flex flex-1 items-center justify-between">
			<div class="text-2xl font-bold tracking-tighter">AN.</div>
			<div class="flex items-center space-x-8">
				<!-- DESKTOP -->
				<div
					class="hidden items-center space-x-8 text-sm font-bold tracking-widest uppercase md:flex">
					{
						menuItems.map((item) => (
							<a class="transition-opacity hover:opacity-70" href={item.link}>
								{item.name}
							</a>
						))
					}
				</div>
				<div class="inline-flex items-center justify-center space-x-4 divide-x text-base">
					<div class="flex items-center justify-center pr-4">
						<ThemeButton class="hover:opacity-70" />
					</div>
					<a
						class="inline-flex h-8 w-8 items-center justify-center hover:opacity-70"
						href="/rss.xml"
						target="_blank">
						<Icon name="tabler:rss" size="24" />
						<span class="sr-only">rss</span>
					</a>
				</div>
			</div>
		</div>
		<!-- MOBILE -->
		<div class="md:hidden">
			<div class="flex items-center space-x-8 text-sm font-bold tracking-widest uppercase">
				{
					menuItems.map((item) => (
						<a class="transition-opacity hover:opacity-70" href={item.link}>
							{item.name}
						</a>
					))
				}
			</div>
		</div>
	</div>
</nav>
