---
interface Props {
	entryId: string;
	title: string;
	description: string;
	techStack: string;
	codeUrl?: string;
	class?: string;
}

const {
	entryId,
	title,
	description,
	techStack,
	codeUrl = "#",
	class: className = "",
} = Astro.props;
---

<article
	class:list={[
		"dark:bg-surface-dark group hover:border-primary flex flex-col border border-gray-200 bg-white p-5 font-mono transition-colors dark:border-gray-700",
		className,
	]}>
	<div class="mb-6 flex items-start justify-between">
		<div class="text-primary bg-black px-1.5 py-0.5 text-[10px] font-black">
			{entryId}
		</div>
	</div>
	<h3 class="mb-3 text-lg leading-none font-black text-gray-900 uppercase dark:text-white">
		{title}
	</h3>
	<div class="mb-6 space-y-4">
		<div class="flex gap-2 text-[10px] leading-relaxed">
			<span class="text-primary font-bold">STATUS:</span>
			<p class="text-gray-600 dark:text-gray-400">
				{description}
			</p>
		</div>
		<div
			class="border-t border-gray-100 pt-2 text-[9px] tracking-tighter text-gray-400 uppercase dark:border-gray-800 dark:text-gray-500">
			{techStack}
		</div>
	</div>
	<div class="mt-auto flex items-center justify-between">
		<a
			class="dark:text-primary text-[10px] font-black text-gray-900 uppercase hover:underline"
			href={codeUrl}>[ VIEW_CODE ]</a
		>
	</div>
</article>
