---
import { cn } from "@/lib/utils";

interface Project {
	tag: string;
	title: string;
	description?: string;
}

interface Props {
	title?: string;
	currentIndex?: number;
	totalCount?: number;
	projects: Project[];
	latency?: string;
	status?: string;
	class?: string;
}

const {
	title = "Stream_X_Latest",
	currentIndex = 1,
	totalCount = 3,
	projects,
	class: className = "",
} = Astro.props;
---

<div
	class={cn(
		"relative flex w-56 flex-col overflow-hidden border p-4 shadow-inner backdrop-blur-md",
		className
	)}>
	<div
		class="mb-8 flex justify-between border-b border-inherit pb-2 text-base text-[9px] font-bold tracking-tighter uppercase">
		<span>{title}</span>
		<span>{String(currentIndex).padStart(2, "0")}/{String(totalCount).padStart(2, "0")}</span>
	</div>
	<div class="space-y-12">
		{
			projects.map((project, index) => (
				<div
					class:list={[
						index === 0 ? "group" : "",
						index === 1 ? "opacity-40" : "",
						index === 2 ? "opacity-20" : "",
					]}>
					<span class="mb-1 block text-[10px] font-black text-inherit/70">{project.tag}</span>
					<h4 class="mb-2 text-sm leading-tight font-bold text-inherit">{project.title}</h4>
					<div class="bg-base/10 mb-3 h-px w-full" />
					{project.description && (
						<p class="text-[11px] leading-relaxed font-medium text-inherit/80 italic">
							{project.description}
						</p>
					)}
				</div>
			))
		}
	</div>
</div>
