---
import { cn } from "@/lib/utils";

interface Props {
	target: number;
	duration?: number;
	delay?: number;
	class?: string;
	prefix?: string;
}

const { target, duration = 1.2, delay = 0, class: className = "", prefix = "" } = Astro.props;
---

<span
	class={cn("tabular-nums", className)}
	data-count-target={target}
	data-count-duration={duration}
	data-count-delay={delay}
	data-count-prefix={prefix}>
	0
</span>

<script>
	import { animate, inView } from "motion";

	document.querySelectorAll<HTMLElement>("[data-count-target]").forEach((el) => {
		const target = Number(el.dataset.countTarget || 0);
		const duration = Number(el.dataset.countDuration || 1.2);
		const delay = Number(el.dataset.countDelay || 0);
		const prefix = String(el.dataset.countPrefix || "");

		inView(
			el,
			() => {
				// @ts-ignore
				animate(0, target, {
					duration,
					delay,
					easing: [0.16, 1, 0.3, 1],
					onUpdate: (v) => {
						el.textContent = `${prefix}${Math.round(v).toString()}`;
					},
				});
			},
			{ amount: 0.5 }
		);
	});
</script>
