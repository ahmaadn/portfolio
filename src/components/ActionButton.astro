---
import { cn } from "@/lib/utils";
import Icon from "astro-iconify";

interface Props {
	href: string;
	icon?: string;
	text: string;
	class?: string;
}

const { href, icon, text, class: className = "" } = Astro.props;
---

<a
	class={cn(
		"bg-main-light text-content border-base flex items-center space-x-3 rounded-none border-l-4 px-8 py-4 text-sm font-black tracking-widest uppercase shadow-xl transition-transform hover:translate-x-2",
		className
	)}
	href={href}>
	{
		icon && (
			<Icon size="18" name={icon} class="text-lg">
				{icon}
			</Icon>
		)
	}
	<span>{text}</span>
</a>
