---
interface Project {
	tag: string;
	title: string;
	description?: string;
}

interface Props {
	title?: string;
	currentIndex?: number;
	totalCount?: number;
	projects: Project[];
	latency?: string;
	status?: string;
}

const {
	title = "Stream_X_Latest",
	currentIndex = 1,
	totalCount = 3,
	projects,
	latency = "12ms",
	status = "ACTIVE",
} = Astro.props;
---

<div
	class="border-neutral/10 bg-neutral/5 relative flex w-56 flex-col overflow-hidden border p-4 shadow-inner backdrop-blur-md">
	<div
		class="text-neutral border-neutral/10 mb-8 flex justify-between border-b pb-2 text-[9px] font-bold tracking-tighter uppercase opacity-60">
		<span>{title}</span>
		<span>{String(currentIndex).padStart(2, "0")}/{String(totalCount).padStart(2, "0")}</span>
	</div>
	<div class="space-y-12">
		{
			projects.map((project, index) => (
				<div
					class:list={[
						index === 0 ? "group" : "",
						index === 1 ? "opacity-40" : "",
						index === 2 ? "opacity-20" : "",
					]}>
					<span class="text-neutral/40 mb-1 block text-[10px] font-black">{project.tag}</span>
					<h4 class="text-neutral mb-2 text-sm leading-tight font-bold">{project.title}</h4>
					<div class="bg-neutral/20 mb-3 h-px w-full" />
					{project.description && (
						<p class="text-[11px] leading-relaxed font-medium text-gray-700 italic">
							{project.description}
						</p>
					)}
				</div>
			))
		}
	</div>
</div>
