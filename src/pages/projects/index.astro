---
import Button from "@/components/Button.astro";
import Footer from "@/components/Footer.astro";
import CountUp from "@/components/motions/CountUp.astro";
import InView from "@/components/motions/InView.astro";
import Stagger from "@/components/motions/Stagger.astro";
import StaggerItem from "@/components/motions/StaggerItem.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import SiteHeading from "@/components/SiteHeading.astro";
import { SITE } from "@/config";
import Layout from "@/layouts/layout.astro";
import { Icon } from "astro-icon/components";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects"))
	.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
	.map((project) => project.data);

const tags = [...new Set(projects.flatMap((project) => project.tags))].sort();

function createSlug(tag: string): string {
	return tag.toLowerCase().replace(/[^a-z0-9]/g, "-");
}
---

<Layout title="Projects" description="Koleksi proyek yang telah saya kerjakan">
	<SiteHeading id="site-heading" class="min-h-150">
		<div
			class="relative z-10 mx-auto flex h-full max-w-6xl flex-col items-start justify-center px-6 pt-24 lg:pt-0">
			<Stagger animation="fade-up">
				<!-- Breadcrumb -->
				<StaggerItem as="nav" class="mb-10">
					<a
						href="/"
						class="text-content-muted hover:text-content group inline-flex items-center gap-2 text-sm transition-colors">
						<Icon
							name="ri:arrow-left-line"
							class="h-4 w-4 transition-transform group-hover:-translate-x-0.5"
						/>
						<span>Back to home</span>
					</a>
				</StaggerItem>

				<div class="flex w-full flex-col gap-16 lg:flex-row lg:items-end lg:justify-between">
					<!-- Left: heading block -->
					<div class="z-20 max-w-2xl">
						<StaggerItem class="mb-4 flex items-center gap-3">
							<div class="bg-primary h-0.5 w-6"></div>
							<span class="text-content-muted text-sm font-medium tracking-widest uppercase">
								Portfolio
							</span>
						</StaggerItem>

						<StaggerItem as="h1" class="text-content mb-6 text-4xl font-bold md:text-6xl">
							Projects
						</StaggerItem>

						<StaggerItem as="p" class="text-lg md:text-xl">
							Jelajahi kumpulan pekerjaan yang telah saya rancang dan bangun, dari aplikasi
							web kompleks hingga aplikasi mobile.
						</StaggerItem>

						<StaggerItem class="mt-8">
							<Button
								as="a"
								url="#main-content"
								label="Browse Projects"
								icon="ri:arrow-down-line"
								variant="invert"
							/>
						</StaggerItem>
					</div>

					<!-- Right: stats block -->
					<StaggerItem class="z-20 shrink-0">
						<div class="grid grid-cols-2 gap-12">
							<div class="flex flex-col items-center">
								<CountUp
									target={projects.length}
									delay={1}
									class="text-content text-4xl font-bold"
								/>
								<span class="text-content-muted mt-2 text-xs tracking-wider uppercase">
									Projects
								</span>
							</div>
							<div class="flex flex-col items-center">
								<CountUp
									target={tags.length}
									delay={1}
									class="text-content text-4xl font-bold"
								/>
								<span class="text-content-muted mt-2 text-xs tracking-wider uppercase">
									Technologies
								</span>
							</div>
						</div>
					</StaggerItem>
				</div>
			</Stagger>
		</div>
	</SiteHeading>

	<main
		id="main-content"
		class="relative min-h-screen w-full space-y-20 pt-12 pb-20 md:space-y-24">
		<div class="container max-w-6xl">
			<InView animation="fade-up">
				<div class="mb-12 flex flex-wrap justify-center gap-1.5 md:gap-2">
					<Button
						as="button"
						variant="ghost"
						data-filter="all"
						label="All"
						class="filter-btn active py-1.5 text-sm font-medium"
					/>

					{
						tags.map((tag) => (
							<Button
								as="button"
								variant="ghost"
								data-filter={createSlug(tag)}
								label={tag}
								class="filter-btn py-1.5 text-sm font-medium"
							/>
						))
					}
				</div>
			</InView>
			<section class="relative">
				<h2 class="sr-only">Daftar Proyek</h2>
				<div
					id="projects-container"
					class="flex flex-col gap-8 md:grid md:grid-cols-2 lg:grid-cols-3">
					{
						projects.map((project, index) => (
							<div
								class="project-item active"
								data-tags={project.tags.map((tag) => createSlug(tag)).join(",")}>
								<ProjectCard project={project} />
							</div>
						))
					}
				</div>
			</section>
		</div>
	</main>

	<InView animation="fade-up">
		<Footer mail={SITE.email} />
	</InView>
</Layout>

<script>
	// @ts-nocheck
	import { animate, inView, stagger } from "motion";

	// --- Initial entrance stagger for project cards ---
	const container = document.getElementById("projects-container");
	if (container) {
		const items = container.querySelectorAll(".project-item");
		items.forEach((el) => {
			el.style.opacity = "0";
			el.style.transform = "translateY(24px)";
		});

		inView(
			container,
			() => {
				animate(
					items,
					{ opacity: [0, 1], transform: ["translateY(24px)", "translateY(0)"] },
					{ duration: 0.55, easing: [0.16, 1, 0.3, 1], delay: stagger(0.07) }
				);
			},
			{ amount: 0.1 }
		);
	}

	// --- Filter logic ---
	/** @type {NodeListOf<HTMLElement>} */
	const filterButtons = document.querySelectorAll(".filter-btn");
	/** @type {NodeListOf<HTMLElement>} */
	const projectItems = document.querySelectorAll(".project-item");

	function setActiveButton(activeButton) {
		filterButtons.forEach((btn) => btn.classList.remove("active"));
		activeButton.classList.add("active");
	}

	function showItems(items) {
		items.forEach((el) => el.classList.add("active"));
		if (items.length) {
			animate(
				items,
				// @ts-ignore
				{ opacity: [0, 1], transform: ["scale(0.95)", "scale(1)"] },
				{ duration: 0.35, easing: [0.16, 1, 0.3, 1], delay: stagger(0.05) }
			);
		}
	}

	function filterProjects(category) {
		const allItems = Array.from(projectItems);
		const toShow = allItems.filter((item) => {
			const itemTags = (item.getAttribute("data-tags") || "").toLowerCase();
			return category === "all" || itemTags.includes(category);
		});

		// Always hide all first, then show matching
		animate(
			allItems,
			// @ts-ignore
			{ opacity: 0, transform: "scale(0.95)" },
			{ duration: 0.2, easing: [0.16, 1, 0.3, 1] }
		).then(() => {
			allItems.forEach((el) => el.classList.remove("active"));
			showItems(toShow);
		});
	}

	filterButtons.forEach((button) => {
		button.addEventListener("click", function () {
			const filter = this.getAttribute("data-filter");
			if (filter) {
				setActiveButton(this);
				filterProjects(filter);
			}
		});
	});
</script>

<style>
	.project-item.active {
		display: block;
		opacity: 100;
	}

	.project-item {
		display: none;
		opacity: 0;
	}
</style>
