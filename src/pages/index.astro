---
import AboutContent from "@/components/about/AboutContent.astro";
import AboutSection from "@/components/about/AboutSection.astro";
import ActionButton from "@/components/ActionButton.astro";
import Avatar from "@/components/Avatar.astro";
import {
	ContactCard,
	ContactEmail,
	ContactLink,
	ContactLinksGrid,
	ContactSection,
} from "@/components/contact";
import {
	EducationDateBadge,
	EducationInfoCard,
	EducationItem,
	EducationSection,
	EducationTitle,
} from "@/components/education";
import FrameImage from "@/components/FrameImage.astro";
import Navbar from "@/components/Navbar.astro";
import { ProjectArticle, ProjectFooter, ProjectGrid, ProjectSection } from "@/components/projects";
import SiteHeading from "@/components/SiteHeading.astro";
import { SkillItem, SkillsMarquee, TechStackSection } from "@/components/tech-stack";
import { EDUCATION, SITE, SKILLS } from "@/config";
import Layout from "@/layouts/layout.astro";
import { getCollection } from "astro:content";

const allProject = (await getCollection("projects")).sort(
	(a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

let latestProject =
	allProject.filter((project) => project.data.latest || false)[0] || allProject[0];

let newProjects = allProject.slice(0, 3).map((project) => project.data);
---

<Layout title="me" description={SITE.shortDescription}>
	<Navbar class="text-neutral" />
	<SiteHeading name={SITE.author} description={SITE.shortDescription} />
	<main>
		<AboutSection id="about">
			<div
				class="border-border-strong scanline flex items-center justify-center border-b py-12 md:col-span-5 md:border-r md:border-b-0 lg:justify-end">
				<div class="max-w-[530px] px-12">
					<FrameImage label="IMG_REF_01">
						<Avatar
							alt={SITE.author}
							class="h-full w-full object-cover grayscale transition-all duration-300 hover:filter-none"
						/>
					</FrameImage>
				</div>
			</div>
			<div class="bg-main flex items-center md:col-span-7">
				<div class="max-w-[762px] p-12">
					<AboutContent tag="Section/Bio/Info_01" title="About Me">
						{SITE.description.map((desc) => <p>{desc}</p>)}
					</AboutContent>
				</div>
			</div>
		</AboutSection>
		<TechStackSection id="tech-stack" tag="Systems/Core/Stack_Registry" title="Tech Stack">
			<SkillsMarquee>
				{SKILLS.map(({ name, icon }) => <SkillItem name={name} icon={icon} />)}
			</SkillsMarquee>
		</TechStackSection>
		<EducationSection class="py-20">
			{
				EDUCATION.map((edu) => (
					<EducationItem class="md:grid md:grid-cols-[1fr_70%] lg:grid-cols-[1fr_80%]">
						<div class="col-span-1">
							<EducationDateBadge from={edu.from} to={edu.to} isCurrent={edu.isCurrent} />
						</div>
						<div class="flex-grow md:contents">
							<EducationTitle
								slot="title"
								institute={edu.institute}
								status={edu?.isCurrent ? "current" : "archive"}
								class="col-span-1 col-start-2"
							/>
							<div class="col-span-1 col-start-2 grid grid-cols-1 gap-4 md:grid-cols-2">
								<EducationInfoCard label="PROGRAM_OF_STUDY" value={edu.course} />
								<EducationInfoCard label="NODE_LOCATION" value={edu.location} />
							</div>
						</div>
					</EducationItem>
				))
			}
		</EducationSection>
		<ProjectSection class="scanline border-b-8 border-black">
			<ProjectGrid>
				{
					newProjects.map((project, index) => (
						<ProjectArticle
							entryId={`ENTRY_${String(index + 1).padStart(2, "0")}`}
							title={project.title}
							description={project.description}
							techStack={project.tags.join(" | ")}
							codeUrl={project.url}
						/>
					))
				}
			</ProjectGrid>
			<ProjectFooter>
				<ActionButton href="/projects" icon="ri:terminal-box-line" text="Access_All_Files" />
			</ProjectFooter>
		</ProjectSection>
		<ContactSection
			tag="Comm/Sync/Channel_Listen"
			title="Get In Touch"
			description="Initiate direct connection. Available for collaboration and freelance data solutions.">
			<ContactCard>
				<ContactEmail email="ahmadnur415@gmail.com" />
				<ContactLinksGrid>
					<ContactLink label="Git_Node" href="#" text="//GITHUB.COM/AHMAADN" />
					<ContactLink label="Identity_File" href="#" text="//GET_RESUME.PDF" />
					<ContactLink label="Network_Socket" href="#" text="//LINKEDIN.COM/IN/AHMAADN" />
				</ContactLinksGrid>
			</ContactCard>
		</ContactSection>
	</main>
	<footer
		class="dark:bg-background-dark border-t border-gray-200 bg-white py-8 dark:border-gray-800">
		<div
			class="mx-auto flex max-w-7xl flex-col items-center justify-between px-6 text-sm text-gray-500 md:flex-row dark:text-gray-400">
			<div class="flex items-center gap-4">
				<span class="text-xl font-black tracking-tighter text-gray-900 dark:text-white"
					>AN.</span
				>
				<p>© 2025 Ahmad Nur Sahid | All rights reserved.</p>
			</div>
			<div class="mt-6 flex gap-8 md:mt-0">
				<p class="font-mono text-[10px] tracking-widest uppercase opacity-50">
					VERIFIED_IDENTITY: 0xF72A1
				</p>
				<p class="font-mono text-[10px] tracking-widest uppercase opacity-50">
					BUILD_STAMP: 20250131
				</p>
			</div>
		</div>
	</footer>
</Layout>
